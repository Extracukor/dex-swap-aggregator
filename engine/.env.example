# Copy this to .env and fill in your values. Never commit .env to git.

# RPC providers (Alchemy primary, Ankr fallback — see constitution constraint)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_RPC_FALLBACK_URL=https://rpc.ankr.com/base

# Contract addresses (filled after Deploy.s.sol runs)
AGGREGATOR_ROUTER_ADDRESS=

# Treasury address (use hardware wallet / multisig — see constitution Principle I)
TREASURY_ADDRESS=

# Basescan (for forge verify-contract)
BASESCAN_API_KEY=
